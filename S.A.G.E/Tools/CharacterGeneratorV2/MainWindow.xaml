<Window x:Class="CharacterGeneratorV2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CharacterGeneratorV2"
        mc:Ignorable="d"
        Title="Character Generator" Height="650" Width="650">
    <Grid Background="#23272A">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0">
            <MenuItem Header="General" Command="{Binding ShowGeneralCommand}"/>
            <MenuItem Header="Graphics" Command="{Binding ShowGraphicsCommand}"/>
            <MenuItem Header="Audio" Command="{Binding ShowAudioCommand}"/>
        </Menu>
        
        <ContentControl Grid.Row="1" Content="{Binding CurrentView}"/>


    </Grid>
</Window>
